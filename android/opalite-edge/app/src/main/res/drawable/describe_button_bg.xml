<?xml version="1.0" encoding="utf-8"?>
<!--
  Describe-button background. Flat rectangle (no rounded corners) so
  the pinned button aligns flush with the screen edge. Enabled state
  uses a blue fill with a white-alpha ripple on press; disabled state
  is flat dim gray.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#222222" />
        </shape>
    </item>
    <item>
        <ripple android:color="#66FFFFFF">
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#1565C0" />
                </shape>
            </item>
        </ripple>
    </item>
</selector>
